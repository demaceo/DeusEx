# Build-time secrets for the podcast generator (scripts/generate-podcast.ts).
# Copy to .env.local (gitignored via *.local) and fill in. These are NEVER
# bundled into the client app — there is no VITE_ prefix on purpose.

# https://elevenlabs.io — used to synthesize each persona's voice.
ELEVENLABS_API_KEY=

# https://console.anthropic.com — used for the conversational rewrite pass.
ANTHROPIC_API_KEY=

# Optional overrides:
# PODCAST_LLM_MODEL=claude-opus-4-8
# PODCAST_TTS_MODEL=eleven_multilingual_v2
